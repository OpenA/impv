#!/usr/bin/bash

# unix socket
IPC='/tmp/impv-socket'

# arguments & files
declare -a mpv_args
declare -a mpv_files

# flags
is_ipc_running=$(if [ -e "$IPC" ]; then lsof "$IPC"; fi)
append_to_list=

# parsing arguments
for i in "$@"; do
	case $i in
	--script-help)
		echo ""
		echo "Usage: impv [options] [FILE(s)]"
		echo ""
		echo "--script-help		# show this help"
		echo "--script-version	# print script version"
		echo "--blank			# open player in pseudo-gui"
		echo "--add-to-playlist	# add files to current list"
		echo ""
		echo "Manpage: https://mpv.io/manual/stable"
		exit
		;;
	--script-version)
		echo "1.0"
		exit
		;;
	--add-to-playlist)
		append_to_list=1
		;;
	--blank ) mpv_args+=('--player-operation-mode=pseudo-gui' '--force-window' '--autofit-smaller=640x480' '--autofit-larger=100%x100%') ;;
	--* | -*) mpv_args+=("$i") ;;
	       *)
		if [ -z "$is_ipc_running" ];
			then mpv_files+=("$i")
			else mpv_files+=("\"$i\",")
		fi
		;;
	esac
done

start_mpv_process() {
	mpv --input-ipc-server="$IPC" "${mpv_args[@]}" "${mpv_files[@]}"
	rm -rf "$IPC"
}

reset_mpv_playlist() {
	# request property ontop
	local t=$(echo '{"command":["get_property","ontop"]}' | socat - "$IPC")
	# restart with new file
	local e=$(echo '{"command":["loadfile",'"${mpv_files[@]}"'"replace"]}' | socat - "$IPC")
	# check if opened correct
	if [[ "$e" =~ '"error"'\s*\:\s*'"success"' ]]; then
		# check if mpv always on top
		if [[ "$t" =~ '"data"'\s*\:\s*false ]]; then
			# place mpv on top
			t=$(echo '{"command":["set_property","ontop",true]}' | socat - "$IPC" && sleep 0.25)
			# restore always_on_top flag
			t=$(echo '{"command":["set_property","ontop",false]}' | socat - "$IPC")
		fi
		e=$(echo '{"command":["set_property","pause",false]}' | socat - "$IPC")
	else
		echo "$e"
	fi
}

addto_mpv_playlist() {
	# check if something played
	local p=$(echo '{"command":["get_property","playback-time"]}' | socat - "$IPC")
	# if playlist has tracks append files or create new playlist
	if [[ "$p" =~ '"error"'\s*\:\s*'"success"' ]];
		then mpv_files+=('"append"')
		else mpv_files+=('"replace"')
	fi
	# send playlist
	local e=$(echo '{"command":["loadfile",'"${mpv_files[@]}"']}' | socat - "$IPC")
	# check errors
	if [[ ! "$e" =~ '"error"'\s*\:\s*'"success"' ]];
		then echo "$e"
	fi
}

if   [   -z "$is_ipc_running" ];
	then start_mpv_process
elif [ ! -z "$append_to_list" ];
	then addto_mpv_playlist
	else reset_mpv_playlist
fi
